{
  "name": "whisperio",
  "version": "1.5.0",
  "author": "Daniel Kasprzyk <daniel@danielkasprzyk.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "description": "Whisperio — Global dictation with hotkey, overlay, and auto-paste. Press hotkey to record, press again to transcribe and paste.",
  "homepage": "https://whisperio.danielkasprzyk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/draenger/whisperio.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build:win": "npm run build && electron-builder --win --config ../.devops/electron-builder.yml",
    "build:mac": "npm run build && electron-builder --mac --config ../.devops/electron-builder.yml",
    "build:linux": "npm run build && electron-builder --linux --config ../.devops/electron-builder.yml",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:fast": "playwright test",
    "test:reachability": "vitest run tests/reachability.spec.ts"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "koffi": "^2.15.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.2.6",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
